// FireNotify System — схема БД
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String   @id @default(cuid())
  login           String   @unique
  passwordHash    String   @map("password_hash")
  name            String?
  role            String   @default("OPERATOR") // ADMIN, OPERATOR, OBSERVER
  telegramId      String?  @unique @map("telegram_id")
  telegramCode    String?  @map("telegram_code")
  telegramEnabled Boolean @default(false) @map("telegram_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt     @map("updated_at")

  messagesSent       Message[] @relation("SentMessages")
  messagesReceived   Message[] @relation("ReceivedMessages")
  messagesRepliedTo  Message[] @relation("AdminReplies")
  actionLogs         ActionLog[]
  assignedNotifications Notification[] @relation("AssignedTo")
  createdNotifications   Notification[] @relation("CreatedNotifications")
  notificationComments   NotificationComment[]
}

model Notification {
  id            String   @id @default(cuid())
  source        String   // источник сигнала
  address       String   // адрес объекта (местонахождение)
  department    String?  // структурное подразделение
  problemType   String?  @map("problem_type")   // тип проблемы / классификация
  status        String   @default("NEW")        // NEW, IN_PROGRESS, VERIFIED, FALSE_ALARM, CLOSED
  description   String?
  comments      String?  // общее поле комментариев (оставлено для совместимости)
  createdById   String?  @map("created_by_id")  // автор обращения
  createdBy     User?    @relation("CreatedNotifications", fields: [createdById], references: [id], onDelete: SetNull)
  assignedToId  String?  @map("assigned_to_id")  // ответственный по зоне ответственности
  assignedTo    User?    @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt     @map("updated_at")
  closedAt      DateTime? @map("closed_at")

  deliveries DeliveryLog[]
  commentThread NotificationComment[]
}

model NotificationComment {
  id             String   @id @default(cuid())
  notificationId String   @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text           String
  createdAt      DateTime @default(now()) @map("created_at")
}

model Message {
  id                String    @id @default(cuid())
  senderId          String    @map("sender_id")
  sender            User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId       String?   @map("recipient_id")
  recipient         User?     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  workObject        String?   @map("work_object") // объект для выполнения работ
  subject           String?
  body              String
  attachmentUrl     String?   @map("attachment_url")
  readAt            DateTime? @map("read_at")
  adminReply        String?   @map("admin_reply")       // ответ администратора оператору
  adminRepliedAt    DateTime? @map("admin_replied_at")
  adminRepliedById  String?   @map("admin_replied_by_id")
  adminRepliedBy    User?     @relation("AdminReplies", fields: [adminRepliedById], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now()) @map("created_at")
}

model DeliveryLog {
  id             String   @id @default(cuid())
  notificationId String   @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        String   // TELEGRAM
  recipient      String?
  success        Boolean
  details        String?
  createdAt      DateTime @default(now()) @map("created_at")
}

model ActionLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String?  // notification, user, message, ...
  entityId  String?  @map("entity_id")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
}
